{
  "name": "ai-forecast-studio",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n web,api -c cyan,green \"vite\" \"tsx watch server/index.ts\"",
    "dev:web": "vite",
    "dev:server": "tsx watch server/index.ts",
    "build": "tsc -b && vite build && tsc -p tsconfig.server.json",
    "db:migrate": "tsx server/migrate.ts",
    "forecast:setup": "uv venv --python 3.12 --clear .venv && uv pip install --python .venv/bin/python -r forecast_engine/requirements.txt",
    "start:server": "node dist-server/index.js",
    "preview": "vite preview",
    "lint": "eslint .",
    "test:server": "tsx --test server/*.test.ts",
    "test:forecast": ".venv/bin/python -m unittest discover -s forecast_engine -p 'test_*.py'"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@vitejs/plugin-react": "latest",
    "cors": "^2.8.6",
    "csv-parse": "^7.0.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.6.0",
    "lucide-react": "latest",
    "multer": "^2.2.0",
    "openai": "^6.48.0",
    "pptxgenjs": "^4.0.1",
    "react": "latest",
    "react-dom": "latest",
    "react-router-dom": "^7.18.1",
    "read-excel-file": "^9.3.2",
    "vite": "latest",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "latest",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.2.0",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "concurrently": "^10.0.3",
    "eslint": "latest",
    "eslint-plugin-react-hooks": "latest",
    "eslint-plugin-react-refresh": "latest",
    "globals": "latest",
    "tsx": "^4.23.1",
    "typescript": "latest",
    "typescript-eslint": "latest"
  }
}
