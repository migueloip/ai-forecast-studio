# Neon pooled connection string from the Neon dashboard.
DATABASE_URL=postgresql://user:password@your-neon-host/neondb?sslmode=require

# NVIDIA OpenAI-compatible inference endpoint.
AI_BASE_URL=https://integrate.api.nvidia.com/v1
AI_API_KEY=nvapi-...
AI_MODEL=openai/gpt-oss-120b
AI_TIMEOUT_MS=300000
AI_MAX_RETRIES=1
AI_MAX_OUTPUT_TOKENS=1200
AI_BRIEFING_MAX_TOKENS=1600
AI_REASONING_EFFORT=low
MEETING_JOB_TIMEOUT_MS=360000

# Encrypts each user's NVIDIA API key before it is stored. Generate once with:
# openssl rand -base64 32
# Keep this stable; changing or losing it makes existing encrypted keys unreadable.
# Put the real value only in ignored .env or a deployment secret manager.
CREDENTIAL_ENCRYPTION_KEY=replace-with-32-byte-base64-key

# Forecast Intelligence Engine scientific runtime.
FORECAST_PYTHON_BIN=.venv/bin/python
FORECAST_ENGINE_TIMEOUT_MS=180000

# Cloudflare Turnstile. The site key is public; keep the secret only in the
# server environment and never expose it through a VITE_ variable.
VITE_TURNSTILE_SITE_KEY=0x4AAAAAAD6vfuCK_JkJoUQE
TURNSTILE_SECRET_KEY=your-turnstile-secret-key
TURNSTILE_TIMEOUT_MS=10000

# For the native OpenAI API, use instead:
# AI_BASE_URL=https://api.openai.com/v1
# AI_API_KEY=sk-proj-...
# AI_MODEL=gpt-5.4-mini

API_PORT=8787
APP_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
MAX_UPLOAD_MB=25
MAX_DATASET_ROWS=50000
